# Copy to .env and fill in your values
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
PORT=3001

# Better Auth — generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
# Public URL of the frontend app. In dev the frontend lives on :5173 (Vite)
# while BETTER_AUTH_URL points at Express on :3001. APP_URL controls where
# verification / password-reset email links land the user.
# In production, set this to your real domain, e.g. https://stash-squirrel.com
APP_URL=http://localhost:5173

# Social providers (optional — leave blank to disable)
# Google redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Stripe (Pro subscriptions) ────────────────────────────────────────────
# Leave blank to disable Stripe. When blank, the Stripe plugin is not
# registered — signup still works and everyone can pick Free.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create the Product + two recurring Prices in Stripe (test mode first):
#   $7/mo  → STRIPE_PRICE_PRO_MONTHLY
#   $70/yr → STRIPE_PRICE_PRO_YEARLY (used as annualDiscountPriceId)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Local-dev webhook forwarding:
#   stripe listen --forward-to localhost:3001/api/auth/stripe/webhook

# ─── Free-tier caps ────────────────────────────────────────────────────────
FREE_TIER_MAX_LISTS=3
FREE_TIER_MAX_ITEMS=50

# ─── API rate limiting (per user per minute) ───────────────────────────────
RATE_LIMIT_FREE_PER_MIN=60
RATE_LIMIT_PRO_PER_MIN=600

# ─── Email verification ────────────────────────────────────────────────────
# Flip to "true" once RESEND_API_KEY + EMAIL_FROM are set below. While false,
# new users can sign up without confirming their email (dev convenience).
REQUIRE_EMAIL_VERIFICATION=false

# Resend API (https://resend.com) — used for email verification + password reset.
# If blank, emails are logged to the server console instead of being sent.
RESEND_API_KEY=
# For quick dev testing: EMAIL_FROM=onboarding@resend.dev (Resend's shared
# sender — can only deliver to the email the Resend account was registered
# with). For production, verify your own domain in Resend and use e.g.
# no-reply@stash-squirrel.com
EMAIL_FROM=
