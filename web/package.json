{
  "name": "web",
  "private": true,
  "version": "0.0.97",
  "type": "module",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"vite\"",
    "server:dev": "tsx watch server/index.ts",
    "build": "vue-tsc -b && vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "preview": "vite preview",
    "auth:migrate": "npx @better-auth/cli@latest migrate -y --config server/auth.ts",
    "db:migrate": "tsx server/scripts/run-migrations.ts",
    "db:backfill-user": "tsx server/scripts/backfill-user.ts",
    "ext:dev": "npm --prefix extension run dev",
    "ext:build": "npm --prefix extension run build"
  },
  "dependencies": {
    "@better-auth/stripe": "^1.6.5",
    "@types/multer": "^2.1.0",
    "better-auth": "^1.6.5",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pinia": "^3.0.4",
    "resend": "^6.12.2",
    "stripe": "^22.0.2",
    "tsx": "^4.21.0",
    "vue": "^3.5.30",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.5"
  }
}
